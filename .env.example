DJANGO_ENV=dev
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:8001,http://localhost:8001
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:8001,http://localhost:8001
DJANGO_LOG_LEVEL=INFO
APP_PORT=8001
NGINX_PORT=8080

# sqlite | postgres
DJANGO_DB_ENGINE=sqlite

# When DJANGO_DB_ENGINE=postgres
POSTGRES_DB=teacher_replacement
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
# local run: 127.0.0.1, docker-compose run: db
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_LOG_LEVEL=INFO
CELERY_CONCURRENCY=2

GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

MAX_CHAT_ATTACHMENT_SIZE=5242880
CHAT_THREAD_LIMIT=200
MAX_DOCX_UPLOAD_SIZE=10485760
MAX_SCHEDULE_UPLOAD_SIZE=10485760
