DJANGO_ENV=dev
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_LOG_LEVEL=INFO

# sqlite | postgres
DJANGO_DB_ENGINE=sqlite

# When DJANGO_DB_ENGINE=postgres
POSTGRES_DB=teacher_replacement
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

MAX_CHAT_ATTACHMENT_SIZE=5242880
CHAT_THREAD_LIMIT=200
MAX_DOCX_UPLOAD_SIZE=10485760
MAX_SCHEDULE_UPLOAD_SIZE=10485760
