DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=your-domain.example,127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=https://your-domain.example
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.example
DJANGO_LOG_LEVEL=INFO
NGINX_PORT=8080
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=true

DJANGO_DB_ENGINE=postgres
POSTGRES_DB=teacher_replacement
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_LOG_LEVEL=INFO
CELERY_CONCURRENCY=2

GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

MAX_CHAT_ATTACHMENT_SIZE=5242880
CHAT_THREAD_LIMIT=200
MAX_DOCX_UPLOAD_SIZE=10485760
MAX_SCHEDULE_UPLOAD_SIZE=10485760
